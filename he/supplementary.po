#: script_checking/error_database.csv
msgid " which does not.\",\"To fix this error, remove any accented letters or special characters from your variable names, function names, and other code elements."
msgstr ""

#: script_checking/error_database.csv
msgid " but not in the code itself."
msgstr ""

#: script_checking/error_database.csv
msgid " change [code]café[/code] to [code]cafe[/code].\""
